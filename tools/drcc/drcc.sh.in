#!/usr/bin/env bash
#===----------------------------------------------------------------------===//
# drcc — Polygeist + DataRecomputation compiler wrapper for SPEC2017
#
# Acts as a drop-in replacement for cc/c++.
# Pipeline: cgeist → dr-opt → mlir-translate → clang (backend)
#
# Required tools (resolved at cmake configure time):
#   CGEIST        — Polygeist C/C++ → MLIR frontend
#   DR_OPT        — mlir-opt with DataRecomputation pass
#   MLIR_TRANSLATE— mlir-translate (MLIR → LLVM IR)
#   CLANG         — clang/clang++ for final codegen + linking
#===----------------------------------------------------------------------===//
set -euo pipefail

# --- Tool paths (filled by cmake) ---
CGEIST="${CGEIST:-@CGEIST_EXECUTABLE@}"
DR_OPT="${DR_OPT:-%%DROPT_EXECUTABLE%%}"
MLIR_OPT="${MLIR_OPT:-@MLIR_OPT_EXECUTABLE@}"
MLIR_TRANSLATE="${MLIR_TRANSLATE:-@MLIR_TRANSLATE_EXECUTABLE@}"
CLANG="${CLANG:-@CLANG_EXECUTABLE@}"

# --- DR pass options (user-tunable via env) ---
: "${DR_PASS_FLAGS:="--pass-pipeline=builtin.module(raise-malloc-to-memref,data-recomputation{dr-recompute=true})"}"
: "${CPU_COST_MODEL_FILE:=}"
: "${DR_STATS_DIR:=}"
: "${DRCC_CGEIST_TIMEOUT:=120}"   # seconds; 0 = no timeout

# cgeist resource directory (compiler built-in headers like stddef.h).
# Auto-detect from the cgeist binary location if not set.
if [[ -z "${CGEIST_RESOURCE_DIR:-}" ]]; then
  CGEIST_RESOURCE_DIR="$(dirname "$CGEIST")/../lib/clang/18"
  if [[ ! -d "$CGEIST_RESOURCE_DIR" ]]; then
    CGEIST_RESOURCE_DIR=""
  fi
fi

# --- Parse arguments ---
# We need to intercept:
#   -c            compile only (no link)
#   -S            emit assembly
#   -E            preprocess only
#   -o <file>     output file
#   source files  (.c, .cpp, .cc, .cxx)
#   everything else → forwarded to cgeist (compile) or clang (link)

MODE="link"  # default: compile + link
OUTPUT=""
SOURCES=()
COMPILE_FLAGS=()
LINK_FLAGS=()
LINK_OBJECTS=()
VERBOSE=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -c)
      MODE="compile"
      shift
      ;;
    -S)
      MODE="asm"
      shift
      ;;
    -E)
      # Preprocessing only: just delegate to clang.
      exec "$CLANG" "$@"
      ;;
    --version)
      echo "drcc (DataRecomputation Compiler) — LLVM + Polygeist + dr-opt"
      "$CLANG" --version 2>/dev/null | head -1 || true
      exit 0
      ;;
    -o)
      OUTPUT="$2"
      shift 2
      ;;
    -v|--verbose)
      VERBOSE=1
      shift
      ;;
    --dr-flags)
      DR_PASS_FLAGS="$2"
      shift 2
      ;;
    --cpu-cost-model-file)
      CPU_COST_MODEL_FILE="$2"
      shift 2
      ;;
    -l*|-L*|-Wl,*)
      LINK_FLAGS+=("$1")
      shift
      ;;
    *.c|*.cpp|*.cc|*.cxx|*.C)
      SOURCES+=("$1")
      shift
      ;;
    *.o|*.a|*.so)
      LINK_OBJECTS+=("$1")
      shift
      ;;
    *)
      COMPILE_FLAGS+=("$1")
      shift
      ;;
  esac
done

log() {
  if [[ "$VERBOSE" -eq 1 ]]; then
    echo "[drcc] $*" >&2
  fi
}

die() {
  echo "drcc: error: $*" >&2
  exit 1
}

# --- Validate tools ---
for tool_var in CGEIST DR_OPT MLIR_OPT MLIR_TRANSLATE CLANG; do
  tool_path="${!tool_var}"
  if [[ ! -x "$tool_path" ]]; then
    die "$tool_var not found or not executable: $tool_path"
  fi
done

# --- Compile with plain clang (fallback when DR pipeline fails) ---
compile_clang_fallback() {
  local src="$1"
  local obj="$2"
  log "FALLBACK: compiling $src with clang (DR pipeline unavailable)"
  echo "[drcc] fallback: $src → clang -O2" >&2
  if [[ "$MODE" == "asm" ]]; then
    "$CLANG" -S "$src" -o "$obj" "${COMPILE_FLAGS[@]}" 2>&1
  else
    "$CLANG" -c "$src" -o "$obj" "${COMPILE_FLAGS[@]}" 2>&1
  fi
}

# --- Compile a single source file through the DR pipeline ---
compile_one() {
  local src="$1"
  local obj="$2"

  local base
  base="$(basename "$src" | sed 's/\.[^.]*$//')"
  local tmpdir
  tmpdir="$(mktemp -d "/tmp/drcc.${base}.XXXXXX")"
  trap "rm -rf '$tmpdir'" EXIT

  local mlir_file="${tmpdir}/${base}.mlir"
  local opt_file="${tmpdir}/${base}.opt.mlir"
  local ll_file="${tmpdir}/${base}.ll"

  # Step 1: C/C++ → MLIR (via Polygeist cgeist)
  # Filter out flags that cgeist doesn't understand (backend-only codegen flags).
  # cgeist uses a custom LLVM option parser and rejects many standard clang flags.
  local cgeist_flags=()
  for flag in "${COMPILE_FLAGS[@]}"; do
    case "$flag" in
      -m32|-m64)            ;;  # architecture flags
      -f*|-fno-*)           ;;  # codegen flags (-fno-strict-aliasing, etc.)
      *)                    cgeist_flags+=("$flag") ;;
    esac
  done

  log "cgeist: $src → $mlir_file"
  local timeout_cmd=()
  if [[ "$DRCC_CGEIST_TIMEOUT" -gt 0 ]] 2>/dev/null; then
    timeout_cmd=(timeout "$DRCC_CGEIST_TIMEOUT")
  fi
  if ! "${timeout_cmd[@]}" "$CGEIST" "$src" \
    -S \
    --function='*' \
    --raise-scf-to-affine \
    ${CGEIST_RESOURCE_DIR:+-resource-dir "$CGEIST_RESOURCE_DIR"} \
    "${cgeist_flags[@]}" \
    -o "$mlir_file" \
    2>&1; then
    compile_clang_fallback "$src" "$obj"
    return
  fi

  # Fixup: cgeist (LLVM 18) emits DLTI entries with vector<Nxi32> but
  # LLVM 22+ expects vector<Nxi64>.  Patch in-place.
  sed -i 's/vector<\([0-9]*\)xi32>/vector<\1xi64>/g' "$mlir_file"

  # Fixup: cgeist represents C struct pointers as memref<?x!llvm.struct<...>>
  # which LLVM 22 MLIR rejects.  Since these are always immediately cast to
  # !llvm.ptr via memref2pointer, rewriting the type is semantically safe.
  local rewriter
  rewriter="$(dirname "$0")/rewrite-struct-memrefs.py"
  if [[ -f "$rewriter" ]]; then
    python3 "$rewriter" "$mlir_file"
  fi

  # Step 2: Run DataRecomputation pass
  local dr_flags="$DR_PASS_FLAGS"

  # When stats collection is enabled, inject dr-test-diagnostics so dr-opt
  # emits per-load classification remarks (SINGLE/MULTI/LEAKED/KILLED) and
  # per-buffer cost-model decisions (RECOMPUTE/KEEP) on stderr.
  if [[ -n "$DR_STATS_DIR" ]]; then
    if [[ "$dr_flags" == *"data-recomputation{"* ]]; then
      dr_flags="${dr_flags/data-recomputation\{/data-recomputation\{dr-test-diagnostics }"
    elif [[ "$dr_flags" == *"data-recomputation"* ]]; then
      dr_flags="${dr_flags/data-recomputation/data-recomputation\{dr-test-diagnostics\}}"
    fi
  fi

  # If a CPU cost model file is specified, inject the option into each pass
  # in the pipeline that supports it.
  if [[ -n "$CPU_COST_MODEL_FILE" ]]; then
    dr_flags="${dr_flags//\}/ cpu-cost-model-file=$CPU_COST_MODEL_FILE\}}"
  fi

  log "dr-opt: $mlir_file → $opt_file"
  if [[ -n "$DR_STATS_DIR" ]]; then
    mkdir -p "$DR_STATS_DIR"
    local stats_file="${DR_STATS_DIR}/${base}.dr-stats"
    if ! "$DR_OPT" --allow-unregistered-dialect "$dr_flags" "$mlir_file" -o "$opt_file" 2>"$stats_file"; then
      cat "$stats_file" >&2
      compile_clang_fallback "$src" "$obj"
      return
    fi
  else
    if ! "$DR_OPT" --allow-unregistered-dialect "$dr_flags" "$mlir_file" -o "$opt_file" 2>&1; then
      compile_clang_fallback "$src" "$obj"
      return
    fi
  fi

  # Step 3: Lower to LLVM dialect, then MLIR → LLVM IR
  local llvm_file="${tmpdir}/${base}.llvm.mlir"
  log "mlir-opt (lowering): $opt_file → $llvm_file"
  if ! "$MLIR_OPT" \
    --lower-affine \
    --convert-scf-to-cf \
    --convert-cf-to-llvm \
    --convert-arith-to-llvm \
    --convert-math-to-llvm \
    --convert-func-to-llvm \
    --convert-index-to-llvm \
    --finalize-memref-to-llvm \
    --reconcile-unrealized-casts \
    "$opt_file" -o "$llvm_file" \
    2>&1; then
    compile_clang_fallback "$src" "$obj"
    return
  fi

  log "mlir-translate: $llvm_file → $ll_file"
  if ! "$MLIR_TRANSLATE" --mlir-to-llvmir "$llvm_file" -o "$ll_file" 2>&1; then
    compile_clang_fallback "$src" "$obj"
    return
  fi

  # Step 4: LLVM IR → object (or assembly)
  if [[ "$MODE" == "asm" ]]; then
    log "clang: $ll_file → $obj (asm)"
    "$CLANG" -S "$ll_file" -o "$obj" "${COMPILE_FLAGS[@]}" 2>&1
  else
    log "clang: $ll_file → $obj"
    "$CLANG" -c "$ll_file" -o "$obj" "${COMPILE_FLAGS[@]}" 2>&1
  fi

  # Sanity check: the MLIR roundtrip can silently drop globals (e.g. const
  # lookup tables, extern variables) that have no in-TU function references.
  # Compare defined global symbols against a clang reference build; if any
  # are missing, recompile with clang to preserve correct linkage.
  if [[ "$MODE" != "asm" && -f "$obj" ]]; then
    local clang_ref="${tmpdir}/${base}.ref.o"
    "$CLANG" -c "$src" -o "$clang_ref" "${COMPILE_FLAGS[@]}" 2>/dev/null
    if [[ -f "$clang_ref" ]]; then
      local dr_syms clang_syms
      dr_syms="$(nm -g --defined-only "$obj" 2>/dev/null | awk '{print $3}' | sort -u)"
      clang_syms="$(nm -g --defined-only "$clang_ref" 2>/dev/null | awk '{print $3}' | sort -u)"
      # If clang defines symbols that the DR pipeline dropped, fall back.
      local missing
      missing="$(comm -23 <(echo "$clang_syms") <(echo "$dr_syms"))"
      if [[ -n "$missing" ]]; then
        log "DR pipeline dropped symbols: $missing"
        echo "[drcc] fallback: $src — DR pipeline dropped symbols" >&2
        cp "$clang_ref" "$obj"
      fi
    fi
  fi
}

# --- No sources: linking only ---
if [[ ${#SOURCES[@]} -eq 0 ]]; then
  if [[ ${#LINK_OBJECTS[@]} -gt 0 ]]; then
    log "link-only: ${LINK_OBJECTS[*]}"
    exec "$CLANG" "${LINK_OBJECTS[@]}" "${LINK_FLAGS[@]}" \
      ${OUTPUT:+-o "$OUTPUT"}
  else
    die "no input files"
  fi
fi

# --- Compile each source ---
OBJECTS=()
for src in "${SOURCES[@]}"; do
  if [[ "$MODE" == "compile" || "$MODE" == "asm" ]]; then
    if [[ -n "$OUTPUT" && ${#SOURCES[@]} -eq 1 ]]; then
      obj="$OUTPUT"
    else
      obj="$(basename "$src" | sed 's/\.[^.]*$/.o/')"
    fi
  else
    obj="$(mktemp "/tmp/drcc.XXXXXX.o")"
  fi
  compile_one "$src" "$obj"
  OBJECTS+=("$obj")
done

# --- Link if needed ---
if [[ "$MODE" == "link" ]]; then
  log "link: ${OBJECTS[*]} ${LINK_OBJECTS[*]}"
  "$CLANG" "${OBJECTS[@]}" "${LINK_OBJECTS[@]}" "${LINK_FLAGS[@]}" \
    ${OUTPUT:+-o "$OUTPUT"} 2>&1
  # Clean up temp objects
  for obj in "${OBJECTS[@]}"; do
    rm -f "$obj"
  done
fi
